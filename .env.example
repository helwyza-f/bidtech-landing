# Copy to .env and fill in real values before running `docker compose up -d`.

DB_PASSWORD=change-me-to-a-strong-password

ADMIN_USERNAME=admin
# Generate with: docker run --rm -v "$PWD/backend:/src" -w /src golang:1.25-alpine go run ./cmd/hashpassword "your-password"
ADMIN_PASSWORD_HASH=$2a$10$replace-with-a-real-bcrypt-hash

# Long random string, e.g: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Origin of the public marketing site (for the public POST /api/orders CORS check).
ALLOWED_ORIGIN=https://bidtech.co.id
